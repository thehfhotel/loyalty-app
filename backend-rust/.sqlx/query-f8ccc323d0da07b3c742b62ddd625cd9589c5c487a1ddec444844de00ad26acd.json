  "query": "\n        INSERT INTO room_blocked_dates (room_id, blocked_date, reason)\n        SELECT $1, d, $3\n          FROM UNNEST($2::date[]) AS d\n        ON CONFLICT (room_id, blocked_date) DO NOTHING\n        RETURNING id, blocked_date, created_at\n        ",
