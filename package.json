{
  "name": "loyalty-app",
  "version": "4.0.1",
  "type": "module",
  "scripts": {
    "install:all": "cd backend-rust && cargo fetch && cd ../frontend && npm ci",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend-rust && cargo build --release",
    "build:frontend": "cd frontend && npm run build",
    "test": "cd backend-rust && cargo test",
    "test:all": "npm run test && npm run test:e2e",
    "test:unit": "cd backend-rust && cargo test --lib --bins",
    "test:integration": "cd backend-rust && cargo test --test lib",
    "test:e2e": "E2E_BACKEND_PORT=4202 E2E_DB_PORT=5436 E2E_REDIS_PORT=6381 npx playwright test",
    "test:build-validation": "npx playwright test tests/build-validation.api.spec.ts",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend-rust && cargo clippy --all-targets -- -D warnings",
    "lint:frontend": "cd frontend && npm run lint",
    "typecheck": "npm run typecheck:backend && npm run typecheck:frontend",
    "typecheck:backend": "cd backend-rust && cargo check --all-targets",
    "typecheck:frontend": "cd frontend && npm run typecheck",
    "test:integrity": "./scripts/validate-test-integrity.sh",
    "oauth:reset-limits": "./scripts/reset-rate-limits.sh",
    "db:backup": "./scripts/migration-rollback-safety.sh backup",
    "db:rollback-check": "./scripts/migration-rollback-safety.sh check",
    "quality:check": "npm run lint && npm run typecheck && npm run test:integrity && npm run test",
    "security:audit": "cd frontend && npm audit --audit-level=moderate",
    "dev:backend": "cd backend-rust && cargo run",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "pre-push": "npm run quality:check && npm run security:audit",
    "validate": "npm run install:all && npm run build && npm run quality:check"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "axios": "^1.15.2",
    "canvas": "^3.2.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "allure-playwright": "^3.4.4",
    "concurrently": "^9.2.1",
    "fast-check": "^4.5.3",
    "glob": "^13.0.0"
  }
}
